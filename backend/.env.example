# Copy to .env and fill values. Do NOT commit .env.

# QNAIGC (OpenAI-compatible) base URL
QNAIGC_BASE_URL=https://api.qnaigc.com/v1

# Your API key (keep secret)
QNAIGC_API_KEY=

# Default model for script generation
QNAIGC_MODEL=deepseek/deepseek-v3.2-251201

# Default model for image generation
QNAIGC_IMAGE_MODEL=kling-v2

# Default model for video generation
QNAIGC_VIDEO_MODEL=kling-v2-6

# Local server port
PORT=8787

# Local SQLite database path
SQLITE_PATH=./data/app.db

# Optional: allow browser origin (when not using a dev proxy)
# CORS_ORIGIN=http://localhost:5173
